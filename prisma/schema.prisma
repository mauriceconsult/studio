generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VoiceVariant {
  SYSTEM
  CUSTOM
}

enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OutputFormat {
  MP3_44100
  WAV
  PCM_16000
}

model Voice {
  id String @id @default(cuid())

  // null = system/platform voice, set = org-specific custom voice
  orgId String?

  name        String
  description String?
  category    VoiceCategory @default(GENERAL)
  language    String        @default("en-US")
  variant     VoiceVariant
  r2ObjectKey String?
  previewUrl  String?

  generations Generation[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([variant])
  @@index([orgId])
  @@index([deletedAt])
}

model Generation {
  id String @id @default(cuid())

  orgId  String
  // userId kept for audit trail — who in the org triggered this
  userId String?  // ← optional, not required for access control

  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  // Input
  text         String
  outputFormat OutputFormat @default(MP3_44100)

  // Voice snapshot at generation time
  voiceName     String
  voiceLanguage String?
  voiceCategory String?

  // Generation settings
  temperature       Float
  topP              Float
  topK              Int
  repetitionPenalty Float

  // Output
  r2ObjectKey     String?
  durationSeconds Float?
  charactersUsed  Int?
  fileSize        Int?

  // Status
  status       GenerationStatus @default(PENDING)
  errorMessage String?

  usageRecord UsageRecord?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orgId])
  @@index([orgId, createdAt]) // ← history queries
  @@index([voiceId])
  @@index([status])
}

model UsageRecord {
  id String @id @default(cuid())

  orgId        String
  generationId String?     @unique
  generation   Generation? @relation(fields: [generationId], references: [id])

  charactersUsed Int
  month          Int       // 1-12
  year           Int

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([orgId, month, year]) // ← fast monthly usage queries
}
model Job {
  id        String   @id @default(cuid())
  status    String
  progress  Int      @default(0)
  result    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

