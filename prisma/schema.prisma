generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum VoiceVariant {
  SYSTEM
  CUSTOM
}

enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OutputFormat {
  MP3_44100
  WAV
  PCM_16000
}

model Voice {
  id String @id @default(cuid())

  // null = system/platform voice, set = org-specific custom voice
  orgId String?

  name        String
  description String?
  category    VoiceCategory @default(GENERAL)
  language    String        @default("en-US")
  variant     VoiceVariant
  r2ObjectKey String?
  previewUrl  String?

  generations Generation[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([variant])
  @@index([orgId])
  @@index([deletedAt])
}

model Generation {
  id String @id @default(cuid())

  orgId  String
  // userId kept for audit trail — who in the org triggered this
  userId String?  // ← optional, not required for access control

  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  // Input
  text         String
  outputFormat OutputFormat @default(MP3_44100)

  // Voice snapshot at generation time
  voiceName     String
  voiceLanguage String?
  voiceCategory String?

  // Generation settings
  temperature       Float
  topP              Float
  topK              Int
  repetitionPenalty Float

  // Output
  r2ObjectKey     String?
  durationSeconds Float?
  charactersUsed  Int?
  fileSize        Int?

  // Status
  status       GenerationStatus @default(PENDING)
  errorMessage String?

  usageRecord UsageRecord?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orgId])
  @@index([orgId, createdAt]) // ← history queries
  @@index([voiceId])
  @@index([status])
}

model UsageRecord {
  id String @id @default(cuid())

  orgId        String
  generationId String?     @unique
  generation   Generation? @relation(fields: [generationId], references: [id])

  charactersUsed Int
  month          Int       // 1-12
  year           Int

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([orgId, month, year]) // ← fast monthly usage queries
}
model Job {
  id        String   @id @default(cuid())
  status    String
  progress  Int      @default(0)
  result    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
// prisma/schema.prisma (billing additions only — merge with your existing schema)

// ─── MoMo Subscription ────────────────────────────────────────────────────────
// Tracks active plans for Ugandan users paid via MTN MoMo.
// International users are tracked entirely in Polar; this table is MoMo-only.

model MomoSubscription {
  id          String   @id @default(cuid())
  orgId       String   @unique
  plan        String   // "starter" | "pro"
  status      String   // "active" | "expired" | "cancelled"
  phone       String
  referenceId String   // MoMo transaction reference
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  credits     MomoCredits?
}

// ─── MoMo Credit Ledger ───────────────────────────────────────────────────────
// Tracks remaining included units and PAYG top-up balance for MoMo users.
// Polar handles this natively via meters; we replicate the concept for MoMo.

model MomoCredits {
  id                     String   @id @default(cuid())
  orgId                  String   @unique
  subscriptionId         String   @unique

  // Included plan units (reset monthly)
  minutesRemaining  Int  @default(0)
  charsRemaining         Int      @default(0)
  voicesRemaining        Int      @default(0)

  // PAYG top-up balance in UGX (carried over, never expires)
  topUpBalanceUgx        Int      @default(0)

  updatedAt              DateTime @updatedAt

  subscription           MomoSubscription @relation(fields: [subscriptionId], references: [id])
}

// ─── MoMo Top-Up Requests ────────────────────────────────────────────────────
// Tracks inline PAYG top-up payments initiated mid-generation.

model MomoTopUp {
  id          String   @id @default(cuid())
  orgId       String
  phone       String
  amountUgx   Int
  meter       String   // "videos_generated" | "characters_synthesized" | "voices_cloned"
  quantity    Int      // units being topped up
  referenceId String?  // MoMo transaction reference (set after initiation)
  status      String   @default("pending") // "pending" | "successful" | "failed"
  jobId       String?  // if top-up is tied to a paused job
  createdAt   DateTime @default(now())
}

// Add these models to your existing schema.prisma
// They follow the same ownership pattern as your existing Generation model
// (userId + organizationId for Clerk multi-tenancy)

enum JobStatus {
  pending
  processing
  done
  error
}

model Course {
  id             String    @id @default(cuid())
  userId         String
  organizationId String

  title          String
  script         String    @db.Text

  status         JobStatus @default(pending)
  progress       Int       @default(0)

  // Structured output from PLATFORM_API — stored as JSON
  result         Json?

  externalJobId  String?   // ID returned by PLATFORM_API_URL
  errorMessage   String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}

model Video {
  id             String    @id @default(cuid())
  userId         String
  organizationId String

  title          String
  script         String    @db.Text

  status         JobStatus @default(pending)
  progress       Int       @default(0)

  // R2 URL of the rendered video, populated when status = done
  outputUrl      String?

  externalJobId  String?   // ID returned by INSTASKUL_URL
  errorMessage   String?

  // Optional: duration in seconds, populated after rendering
  durationSeconds Int?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([organizationId])
  @@index([status])
}



