// Replace the existing UsageRecord model in studio/prisma/schema.prisma
// and update ImageGeneration + TextGeneration to remove the broken usageRecord relation field.
// The relation is now owned by UsageRecord (it holds the FK), not the generation models.

model UsageRecord {
  id String @id @default(cuid())

  orgId          String
  month          Int       // 1–12
  year           Int

  // ── Polymorphic generation source ──────────────────────────────────────────
  // Exactly one of these will be set per row. The others are null.
  // This replaces the single generationId field that only covered TTS.

  generationId      String?          @unique
  generation        Generation?      @relation(fields: [generationId], references: [id])

  imageGenerationId String?          @unique
  imageGeneration   ImageGeneration? @relation(fields: [imageGenerationId], references: [id])

  textGenerationId  String?          @unique
  textGeneration    TextGeneration?  @relation(fields: [textGenerationId], references: [id])

  // ── Consumed units (what was charged) ─────────────────────────────────────
  // Set the relevant field, leave others null.
  // Keeps per-type metering separate so billing stays clean.

  charactersUsed Int?    // TTS: characters synthesised
  imagesUsed     Int?    // Image: number of images generated (usually 1)
  tokensUsed     Int?    // Text: LLM tokens consumed

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([orgId, month, year])
  @@map("usage_records")
}

// ── Updated ImageGeneration — relation field removed, back-relation added ────
// Remove `usageRecord UsageRecord?` from the model body.
// Prisma infers the back-relation from UsageRecord's imageGenerationId FK.
// The corrected model:

model ImageGeneration {
  id             String           @id @default(cuid())
  orgId          String
  platformUserId String?
  prompt         String           @db.Text
  style          String?
  outputUrl      String?
  width          Int              @default(1200)
  height         Int              @default(630)
  status         GenerationStatus @default(PENDING)
  errorMessage   String?
  sourceApp      String           @default("zuriah")
  sourceEntityId String?

  // Back-relation — owned by UsageRecord
  usageRecord    UsageRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([platformUserId])
  @@index([status])
  @@map("image_generations")
}

// ── Updated TextGeneration — same fix ────────────────────────────────────────

model TextGeneration {
  id             String           @id @default(cuid())
  orgId          String
  platformUserId String?
  type           String
  prompt         String           @db.Text
  output         String?          @db.Text
  tokensUsed     Int?
  status         GenerationStatus @default(PENDING)
  errorMessage   String?
  sourceApp      String           @default("zuriah")
  sourceEntityId String?

  // Back-relation — owned by UsageRecord
  usageRecord    UsageRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([platformUserId])
  @@index([type])
  @@map("text_generations")
}
